{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "default_agent": "planner",
  "subagent_depth": 1,
  "snapshot": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 4
  },
  "instructions": [
    ".workflow/instructions/AGENTS.md"
  ],
  "provider": {
    "zhipuai-coding-plan": {
      "options": {
        "timeout": false,
        "headerTimeout": false
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}",
        "timeout": false,
        "headerTimeout": false
      },
      "models": {
        "deepseek-v4-pro": {
          "name": "DeepSeek V4 Pro",
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        }
      }
    },
    "kimi": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Moonshot Kimi",
      "options": {
        "baseURL": "https://api.kimi.com/coding/v1",
        "apiKey": "{env:KIMI_API_KEY}",
        "timeout": false,
        "headerTimeout": false
      },
      "models": {
        "k3": {
          "name": "Kimi K3"
        }
      }
    },
    "mimo": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "MiMo",
      "options": {
        "baseURL": "https://token-plan-cn.xiaomimimo.com/v1",
        "apiKey": "{env:MIMO_API_KEY}",
        "timeout": false,
        "headerTimeout": false
      },
      "models": {
        "mimo-v2.5-pro": {
          "name": "mimo-v2.5-pro",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          }
        },
        "mimo-v2.5": {
          "name": "mimo-v2.5",
          "limit": {
            "context": 1048576,
            "output": 131072
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        }
      }
    }
  },
  "permission": {
    "external_directory": "deny"
  }
}

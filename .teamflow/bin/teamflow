#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
RUNTIME_DIR="$ROOT_DIR/.teamflow"
TEAMFLOW_HOME="${TEAMFLOW_HOME:-${WORKFLOW_HOME:-$HOME/.teamflow}}"
cd "$ROOT_DIR"

export OPENCODE_CONFIG="$RUNTIME_DIR/config.json"
export OPENCODE_CONFIG_DIR="$RUNTIME_DIR"

INHERITED_KIMI_API_KEY="${KIMI_API_KEY:-}"
INHERITED_ZHIPU_API_KEY="${ZHIPU_API_KEY:-}"
INHERITED_MIMO_API_KEY="${MIMO_API_KEY:-}"
INHERITED_DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY:-}"
for env_file in "$TEAMFLOW_HOME/.env" "$RUNTIME_DIR/.env"; do
  if [[ ! -f "$env_file" ]]; then continue; fi
  set -a
  # shellcheck disable=SC1091
  source "$env_file"
  set +a
done
if [[ -n "$INHERITED_KIMI_API_KEY" ]]; then
  export KIMI_API_KEY="$INHERITED_KIMI_API_KEY"
fi
if [[ -n "$INHERITED_ZHIPU_API_KEY" ]]; then
  export ZHIPU_API_KEY="$INHERITED_ZHIPU_API_KEY"
fi
if [[ -n "$INHERITED_MIMO_API_KEY" ]]; then
  export MIMO_API_KEY="$INHERITED_MIMO_API_KEY"
fi
if [[ -n "$INHERITED_DEEPSEEK_API_KEY" ]]; then
  export DEEPSEEK_API_KEY="$INHERITED_DEEPSEEK_API_KEY"
fi

if [[ "${1:-}" == "memory" ]]; then
  shift
  exec "$RUNTIME_DIR/bin/memory" "$@"
fi

if [[ "${1:-}" == "memory-capture" ]]; then
  shift
  exec "$RUNTIME_DIR/bin/memory-capture" "$@"
fi

if [[ "${1:-}" == "test-patch" ]]; then
  shift
  exec "$RUNTIME_DIR/bin/test-patch" "$@"
fi

if [[ "${1:-}" == "source-check" ]]; then
  shift
  exec python3 "$RUNTIME_DIR/skills/implement-change/scripts/source_safety.py" "$@"
fi

if [[ "${1:-}" == "phase" ]]; then
  shift
  exec python3 "$RUNTIME_DIR/skills/plan-change/scripts/phase_state.py" "$@"
fi

if [[ "${1:-}" == "command" ]]; then
  shift
  exec opencode run --agent command "$@"
fi

exec opencode "$@"

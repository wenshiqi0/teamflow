#!/usr/bin/env bash
set -euo pipefail

# agent-workflow-launcher
TARGET_INPUT="${WORKFLOW_PROJECT:-$PWD}"
TARGET_ROOT="$(git -C "$TARGET_INPUT" rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$TARGET_ROOT" ]]; then
  echo "error: workflow must run inside an initialized Git project" >&2
  exit 1
fi

RUNTIME="$TARGET_ROOT/.workflow/bin/workflow"
if [[ ! -x "$RUNTIME" ]]; then
  echo "error: workflow is not initialized in $TARGET_ROOT" >&2
  echo "Run the workflow initializer for this project first." >&2
  exit 1
fi

exec "$RUNTIME" "$@"
